{
  "name": "augmenta-care",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "node --import \"data:text/javascript,import { register } from 'node:module'; import { pathToFileURL } from 'node:url'; register('./tests/alias-resolver.mjs', pathToFileURL('./'));\" --test --experimental-strip-types tests/**/*.test.ts",
    "brevo:provision": "node --experimental-strip-types scripts/brevo-provision.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "clsx": "^2.1.1",
    "next": "15.5.19",
    "postcss": "^8.5.16",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "10.0.1",
    "husky": "9.1.7",
    "lint-staged": "15.4.1",
    "prettier": "3.4.2",
    "typescript": "5.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
