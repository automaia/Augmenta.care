# --- Stripe (pré-vente checkout) -----------------------------------------------
# Test mode keys (préfix sk_test_ / pk_test_) for local/staging; live keys
# (sk_live_ / pk_live_) for production. Get them from
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_...) from
# https://dashboard.stripe.com/webhooks → "Add endpoint" → URL
# https://<domain>/api/stripe/webhook → reveal secret.
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs (price_...) for the 2 founder products. Create in the
# Stripe dashboard → Products → "Augmenta — Pré-vente fondateur" with
#   - 29 € recurring (monthly) — id stored here
#   - 290 € one-shot (yearly)  — id stored here
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
# Optional — when true, server-side code uses Stripe test mode helpers
# (test clock, 4242 4242 4242 4242 test card, etc.) Defaults to false.
STRIPE_TEST_MODE=false

# --- Brevo (transactional email + list + webhook) --------------------------------
# Get the API key from Brevo → Settings → SMTP & API → API keys → Generate.
# The free tier (300 emails/day) is enough for the 30-contact founder wave.
BREVO_API_KEY=
# Same value must be set as the secret in the Brevo webhook config.
# Generate with: openssl rand -hex 32
BREVO_WEBHOOK_SECRET=
# Sender identity used as `from:` on every founder email. Must be verified in
# Brevo (Senders & domains) before real sends work.
BREVO_SENDER_EMAIL=fondateur@augmenta.care
BREVO_SENDER_NAME=Antoine — Augmenta
BREVO_REPLY_TO=fondateur@augmenta.care
# Optional override of the API base URL (only for tests or EU isolation).
BREVO_API_BASE=https://api.brevo.com/v3
# IDs returned by scripts/brevo-provision.ts (after running it once).
BREVO_LIST_FOUNDING_WAITLIST_ID=
BREVO_LIST_FOUNDING_UNSUBSCRIBES_ID=
BREVO_TEMPLATE_ID_1=
BREVO_TEMPLATE_ID_2=
BREVO_TEMPLATE_ID_3=

# --- Admin endpoints (auth + dry-run + confirmation) ----------------------------
# Shared secret required by every /api/admin/* route. Send it as:
#   Authorization: Bearer $ADMIN_API_TOKEN   OR   X-Admin-Token: $ADMIN_API_TOKEN
ADMIN_API_TOKEN=
# Optional: when set, every real (non-dry-run) /api/admin/email/send POST must
# include the same value in the JSON body as `confirmationToken`. Hard guard
# against accidental bulk sends. Dry-run ignores it.
EMAIL_SEND_CONFIRMATION_TOKEN=
# Cap how many contacts a single send POST will touch. Default 50.
EMAIL_SEND_BATCH_SIZE=50

# --- Store / file paths ---------------------------------------------------------
# Where the JSON store lives. Defaults to ./data/store.json. Override only in
# tests or containerized deploys (e.g. Clever Cloud FS add-on path).
PAPERCLIP_STORE_PATH=

# --- Routing / public URLs ------------------------------------------------------
# Public pre-vente URL injected in the email body and CTA. The {jX} tag is
# literally replaced in the copy by the J+0 / J+3 / J+7 sequence number.
PRE_SALE_URL=https://www.augmenta.care/pre-vente?utm_source=email&utm_medium=jX&utm_campaign=founding&utm_content=FOUNDING20
# Public base for the one-click unsubscribe link embedded in every email.
UNSUBSCRIBE_BASE_URL=https://www.augmenta.care/api/email/unsubscribe

# --- WithAllo voice-calls (agent vocal IA, AUGA-99) ----------------------------
# Shared HMAC secret used to sign WithAllo "call ended" webhooks. Generate with:
#   openssl rand -hex 32
# Configure the same value in the WithAllo webhook target URL config.
WITHALLO_WEBHOOK_SECRET=
# Optional — when set, the /api/webhooks/voice-call-ended route auto-creates a
# Paperclip issue per inbound call (routed by intention). Leave empty in dev to
# simply persist the call record without creating a ticket.
WITHALLO_PAPERCLIP_API_URL=
WITHALLO_PAPERCLIP_API_TOKEN=
WITHALLO_PAPERCLIP_COMPANY_ID=
# Optional — parent issue id (AUGA-62 voice agent) to attach tickets to.
WITHALLO_PAPERCLIP_PARENT_ISSUE_ID=
# Optional — goal id to attach created tickets to.
WITHALLO_PAPERCLIP_GOAL_ID=

# --- Cellar Clever Cloud HDS — patient attachments (AUGA-132) -------------------
# All patient attachment bytes (PDF compte-rendu, imagerie, attestations) live
# on the HDS Cellar addon `cellar-fr-north-hds-c1.services.clever-cloud.com`
# (shared with WithAllo transcripts — see AUGA-99). Keys are signed via SigV4
# (24h TTL) and never include patient PII.
# Override endpoint / region only when pointing at a non-prod HDS bucket.
S3_HDS_ENDPOINT=cellar-fr-north-hds-c1.services.clever-cloud.com
S3_HDS_REGION=fr-north-hds
# Bucket name. Provision in Clever Cloud console → Cellar add-on → Buckets.
S3_HDS_BUCKET=
# Access key + secret generated in the Cellar add-on → "Access keys" tab.
# Never commit the real values. Inject via `clever env set` on prod.
S3_HDS_ACCESS_KEY_ID=
S3_HDS_SECRET_ACCESS_KEY=
# Optional — global prefix prepended to every key (no trailing slash).
# Leave empty in single-tenant dev; set to e.g. "augmenta" on prod.
S3_HDS_KEY_PREFIX=
# V1 feature flag — when true, the /api/patient-attachments route accepts
# application/dicom. Off by default (DICOM out of V1 scope per AUGA-132).
PATIENT_ATTACHMENTS_DICOM_ENABLED=false
